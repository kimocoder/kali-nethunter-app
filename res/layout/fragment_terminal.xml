<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:id="@+id/terminal_content_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <FrameLayout
            android:id="@+id/terminal_output_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/terminal_recycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never"
                android:scrollbars="vertical"
                android:background="@drawable/bg_card_tech"
                android:clipToPadding="false"
                android:paddingBottom="72dp" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_go_bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="12dp"
                android:contentDescription="@string/terminal_button_goto_bottom"
                android:visibility="gone"
                app:srcCompat="@drawable/ic_arrow_downward"
                app:useCompatPadding="true"
                app:backgroundTint="?attr/colorPrimary"
                app:tint="@android:color/white" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_copy_terminal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="12dp"
                android:visibility="gone"
                android:contentDescription="@string/terminal_text_copy"
                app:srcCompat="@drawable/ic_share_black_24dp"
                app:useCompatPadding="true"
                app:backgroundTint="?attr/colorPrimary"
                app:tint="@android:color/white" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fab_fullscreen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:visibility="gone"
                android:contentDescription="@string/terminal_toggle_fullscreen"
                app:srcCompat="@drawable/ic_fullscreen"
                app:useCompatPadding="true"
                app:fabSize="mini"
                app:backgroundTint="?attr/colorSecondary"
                app:tint="@android:color/white" />
        </FrameLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/keyboard_container_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardElevation="6dp"
            app:cardUseCompatPadding="true"
            app:strokeColor="?attr/colorPrimary"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/system_card_bg"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.MediumComponent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:id="@+id/key_toolbar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:weightSum="3">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_esc"
                        style="@style/Tech.Button.Primary.Compact"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/terminal_button_esc"
                        android:tooltipText="@string/terminal_button_esc"
                        app:cornerRadius="12dp"
                        app:rippleColor="@color/system_tab_ripple"
                        tools:targetApi="26" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_up"
                        style="@style/Tech.Button.Primary.Compact"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/terminal_button_arrow_up"
                        android:tooltipText="@string/terminal_button_arrow_up"
                        app:cornerRadius="12dp"
                        app:rippleColor="@color/system_tab_ripple"
                        tools:targetApi="26" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_down"
                        style="@style/Tech.Button.Primary.Compact"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/terminal_button_arrow_down"
                        android:tooltipText="@string/terminal_button_arrow_down"
                        app:cornerRadius="12dp"
                        app:rippleColor="@color/system_tab_ripple"
                        tools:targetApi="26" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/key_toolbar_ctrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:weightSum="3">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_tab"
                        style="@style/Tech.Button.Primary.Compact"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/terminal_button_tab"
                        android:tooltipText="@string/terminal_button_tab"
                        app:cornerRadius="12dp"
                        app:rippleColor="@color/system_tab_ripple"
                        tools:targetApi="26" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_ctrl"
                        style="@style/Tech.Button.Primary.Compact"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/terminal_button_ctrl"
                        android:tooltipText="@string/terminal_button_ctrl"
                        app:cornerRadius="12dp"
                        app:rippleColor="@color/system_tab_ripple"
                        tools:targetApi="26" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/terminal_cmd_clear"
                        style="@style/Tech.Button.Outlined.Compact"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/terminal_button_clear"
                        android:tooltipText="@string/terminal_button_clear"
                        app:cornerRadius="12dp"
                        app:rippleColor="@color/system_tab_ripple"
                        tools:targetApi="26" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/input_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/input_layout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="@string/terminal_hint_enter_command"
                        app:boxBackgroundMode="filled"
                        app:boxBackgroundColor="@color/system_card_bg"
                        app:boxStrokeColor="?attr/colorPrimary"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:hintTextColor="@color/md_theme_dark_onSurfaceVariant"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_send"
                        app:endIconContentDescription="@string/terminal_send_command_desc">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/input_edit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:autofillHints=""
                            android:imeOptions="actionSend|flagNoFullscreen"
                            android:importantForAutofill="no"
                            android:inputType="textNoSuggestions|textVisiblePassword"
                            android:maxLines="1"
                            android:textColor="@color/md_theme_dark_onSurface"
                            android:fontFamily="monospace" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>